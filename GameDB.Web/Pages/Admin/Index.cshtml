@page "/Admin"
@model GameDB.Web.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Адмін-панель";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
}

<div class="admin-page">
    <form method="post" class="d-none" id="antiForgeryForm">
        @Html.AntiForgeryToken()
    </form>

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h1 class="h3 mb-1">Адмін-панель</h1>
            <p class="text-muted small mb-0">Імпорти, синхронізація цін і покриття даних по іграх</p>
        </div>
        <button type="button" class="btn btn-outline-secondary btn-sm" id="btnRefreshAll">↻ Оновити</button>
    </div>

    
    @* ── Stats ───────────────────────────────────────────────────────────  *@
    <div class="row g-3 mb-4" id="statsCards">
        <div class="col-md-4 col-lg-2">
            <div class="admin-stat-card">
                <div class="admin-stat-label">Всього ігор</div>
                <div class="admin-stat-value" data-stat="total">—</div>
            </div>
        </div>
        <div class="col-md-4 col-lg-2">
            <div class="admin-stat-card admin-stat-ok">
                <div class="admin-stat-label">Full (деталі)</div>
                <div class="admin-stat-value" data-stat="statusFull">—</div>
            </div>
        </div>
        <div class="col-md-4 col-lg-2">
            <div class="admin-stat-card admin-stat-warn">
                <div class="admin-stat-label">Basic (без деталей)</div>
                <div class="admin-stat-value" data-stat="statusBasic">—</div>
            </div>
        </div>
        <div class="col-md-4 col-lg-2">
            <div class="admin-stat-card admin-stat-ok">
                <div class="admin-stat-label">З ціною</div>
                <div class="admin-stat-value" data-stat="withPrice">—</div>
            </div>
        </div>
        <div class="col-md-4 col-lg-2">
            <div class="admin-stat-card admin-stat-warn">
                <div class="admin-stat-label">Без ціни</div>
                <div class="admin-stat-value" data-stat="withoutPrice">—</div>
            </div>
        </div>
        <div class="col-md-4 col-lg-2">
            <div class="admin-stat-card admin-stat-danger">
                <div class="admin-stat-label">Basic без ціни</div>
                <div class="admin-stat-value" data-stat="basicWithoutPrice">—</div>
            </div>
        </div>
    </div>

    
    @* ── Operation panels ───────────────────────────────────────────────  *@
    <div class="row g-3 mb-4">

        
    @* Catalog import — fire-and-forget, per-store or all  *@
        <div class="col-lg-4">
            <div class="admin-panel">
                <h2 class="h6 admin-panel-title">Каталоги магазинів</h2>
                <p class="small text-muted mb-3">Базовий список ігор — додає нові, не торкає існуючі.</p>
                <div class="d-grid gap-2 mb-2" id="catalogImportBtns">
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-import-provider="steam">
                        🎮 Steam
                    </button>
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-import-provider="gog">
                        🌌 GOG
                    </button>
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-import-provider="epic">
                        ⚡ Epic Games
                    </button>
                    <button type="button" class="btn btn-primary btn-sm" data-import-provider="">
                        🚀 Усі (паралельно)
                    </button>
                </div>
                <div class="admin-job-status d-none" id="basicImportStatus"></div>
            </div>
        </div>

        
    @* Enrichment — background job, indeterminate progress  *@
        <div class="col-lg-4">
            <div class="admin-panel">
                <h2 class="h6 admin-panel-title">Збагачення ігор</h2>
                <p class="small text-muted mb-3">
                    Деталі та метадані з магазинів. Черга: <strong id="pendingDetails">—</strong>
                </p>
                <div class="form-check form-switch small mb-3">
                    <input class="form-check-input" type="checkbox" id="enrichOverwrite" />
                    <label class="form-check-label" for="enrichOverwrite">Перезаписувати існуючі дані</label>
                </div>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-primary btn-sm flex-grow-1" id="btnEnrichStart">
                        ▶ Запустити
                    </button>
                    <button type="button" class="btn btn-outline-danger btn-sm" id="btnEnrichStop" title="Зупинити">
                        ■
                    </button>
                </div>
                <div class="admin-progress d-none mt-2" id="enrichProgressWrap">
                    <div class="progress">
                        <div class="progress-bar progress-bar-striped progress-bar-animated"
                             id="enrichProgressBar" style="width: 100%"></div>
                    </div>
                    <div class="small text-muted mt-1" id="enrichProgressText"></div>
                </div>
                <div class="admin-job-status mt-2" id="enrichmentJobStatus"></div>
            </div>
        </div>

        
    @* Price sync — background job, determinate progress  *@
        <div class="col-lg-4">
            <div class="admin-panel">
                <h2 class="h6 admin-panel-title">Синхронізація цін</h2>
                <p class="small text-muted mb-3">
                    Остання синхронізація: <span id="lastPriceSync">—</span>
                </p>
                <div class="input-group input-group-sm mb-2">
                    <span class="input-group-text">Батч</span>
                    <input type="number" class="form-control" id="priceBatchSize" value="100" min="1" max="200" />
                </div>
                <div class="d-flex gap-2 mb-3">
                    <button type="button" class="btn btn-primary btn-sm flex-grow-1" id="btnPriceStart">
                        ▶ Усі ціни
                    </button>
                    <button type="button" class="btn btn-outline-danger btn-sm" id="btnPriceStop" title="Зупинити">
                        ■
                    </button>
                </div>
                <hr class="my-0 mb-3" />
                <p class="small text-muted mb-1">Тільки не синхронізовані після:</p>
                <div class="input-group input-group-sm mb-2">
                    <span class="input-group-text">Дата</span>
                    <input type="date" class="form-control" id="priceSinceDate" />
                    <button type="button" class="btn btn-outline-primary btn-sm" id="btnPriceSinceStart"
                            title="Синхронізувати з цієї дати">▶</button>
                </div>
                <div class="admin-progress d-none mt-2" id="priceProgressWrap">
                    <div class="progress">
                        <div class="progress-bar" id="priceProgressBar" style="width: 0%"></div>
                    </div>
                    <div class="small text-muted mt-1" id="priceProgressText"></div>
                </div>
                <div class="admin-job-status mt-2" id="priceJobStatus"></div>
            </div>
        </div>
    </div>

    
    @* ── Games coverage table ──────────────────────────────────────────────  *@
    <div class="admin-panel">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
            <h2 class="h6 admin-panel-title mb-0">Покриття даних по іграх</h2>
            <div class="d-flex gap-2 flex-wrap align-items-center">
                <input type="search" class="form-control form-control-sm" id="gameSearch"
                       placeholder="Назва або ID…" style="max-width: 200px;" />
                <select class="form-select form-select-sm" id="gameFilter" style="max-width: 220px;">
                    <option value="All">Усі ігри</option>
                    <option value="StatusBasic">Basic (без деталей)</option>
                    <option value="StatusFull">Full (з деталями)</option>
                    <option value="NoPrice">Без ціни</option>
                    <option value="HasPrice">З ціною</option>
                    <option value="BasicNoPrice">Basic без ціни</option>
                    <option value="NoExternalId">Без зовнішнього ID</option>
                </select>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-sm table-hover admin-games-table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th><th>Назва</th><th>Steam ID</th>
                        <th>Статус</th><th>Ціна</th><th>Синх. цін</th><th></th>
                    </tr>
                </thead>
                <tbody id="gamesTableBody">
                    <tr><td colspan="7" class="text-muted text-center py-4">Завантаження…</td></tr>
                </tbody>
            </table>
        </div>
        <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap gap-2">
            <span class="small text-muted" id="gamesPagerInfo">—</span>
            <div class="btn-group btn-group-sm">
                <button type="button" class="btn btn-outline-secondary" id="btnPrevPage" disabled>←</button>
                <button type="button" class="btn btn-outline-secondary" id="btnNextPage" disabled>→</button>
            </div>
        </div>
    </div>

    <div id="adminToast" class="admin-toast d-none" role="alert"></div>
</div>

@section Scripts {
    <script src="~/js/admin.js" asp-append-version="true"></script>
}
