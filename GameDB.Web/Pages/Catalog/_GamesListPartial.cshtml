@* _GamesListPartial.cshtml
   Partial для HTMX: сортування, active-filter chips, сітка карток, пагінація.
   Завантажується через hx-get="/Catalog" (hx-target="#games-container")
   та через @await Html.PartialAsync("_GamesListPartial", Model) при першому рендері.
*@
@model GameDB.Web.Pages.Catalog.IndexModel
@using GameDB.Application.DTOs

@{
    var m = Model;

    string SortClass(CatalogSortBy s) =>
        m.SortBy == s ? "sort-link active" : "sort-link";

    string SortArrow(CatalogSortBy s) =>
        m.SortBy == s ? (m.SortDesc ? " ↓" : " ↑") : "";

    bool hasFilters =
        !string.IsNullOrWhiteSpace(m.Search)
        || m.Genres.Count > 0
        || m.Tags.Count > 0
        || m.DeveloperId.HasValue
        || m.PublisherId.HasValue
        || m.ShopId.HasValue
        || m.MinPrice.HasValue
        || m.MaxPrice.HasValue
        || m.MinDiscount.HasValue
        || m.YearFrom.HasValue
        || m.YearTo.HasValue
        || m.MinRating.HasValue
        || m.IsFree == true;
}

@* ── Active-filter chips ─────────────────────────────────────────────────── *@
@if (hasFilters)
{
    <div class="active-filters mb-3">
        @if (!string.IsNullOrWhiteSpace(m.Search))
        {
            <span class="filter-tag">
                🔍 "@m.Search"
                <a class="remove"
                   href="@m.RemoveFilter("search")"
                   hx-get="@m.RemoveFilter("search")"
                   hx-target="#games-container"
                   hx-push-url="true">×</a>
            </span>
        }

        @foreach (var gid in m.Genres)
        {
            var gname = m.Sidebar.Genres.FirstOrDefault(g => g.GenreId == gid)?.Name
                        ?? gid.ToString();
            <span class="filter-tag">
                🎮 @gname
                <a class="remove"
                   href="@m.RemoveGenre(gid)"
                   hx-get="@m.RemoveGenre(gid)"
                   hx-target="#games-container"
                   hx-push-url="true">×</a>
            </span>
        }

        @foreach (var tid in m.Tags)
        {
            var tname = m.Sidebar.Tags.FirstOrDefault(t => t.TagId == tid)?.Name
                        ?? tid.ToString();
            <span class="filter-tag filter-tag--tag">
                🏷 @tname
                <a class="remove"
                   href="@m.RemoveTag(tid)"
                   hx-get="@m.RemoveTag(tid)"
                   hx-target="#games-container"
                   hx-push-url="true">×</a>
            </span>
        }

        @if (m.DeveloperId.HasValue)
        {
            var dname = m.Sidebar.Developers
                            .FirstOrDefault(d => d.DeveloperId == m.DeveloperId.Value)?.Name ?? "";
            <span class="filter-tag">
                👨‍💻 @dname
                <a class="remove"
                   href="@m.RemoveFilter("developerId")"
                   hx-get="@m.RemoveFilter("developerId")"
                   hx-target="#games-container"
                   hx-push-url="true">×</a>
            </span>
        }

        @if (m.PublisherId.HasValue)
        {
            var pname = m.Sidebar.Publishers
                            .FirstOrDefault(p => p.PublisherId == m.PublisherId.Value)?.Name ?? "";
            <span class="filter-tag">
                🏢 @pname
                <a class="remove"
                   href="@m.RemoveFilter("publisherId")"
                   hx-get="@m.RemoveFilter("publisherId")"
                   hx-target="#games-container"
                   hx-push-url="true">×</a>
            </span>
        }

        @if (m.ShopId.HasValue)
        {
            var sname = m.Sidebar.Shops
                            .FirstOrDefault(s => s.ShopId == m.ShopId.Value)?.Name ?? "";
            <span class="filter-tag">
                🛒 @sname
                <a class="remove"
                   href="@m.RemoveFilter("shopId")"
                   hx-get="@m.RemoveFilter("shopId")"
                   hx-target="#games-container"
                   hx-push-url="true">×</a>
            </span>
        }

        @if (m.MinPrice.HasValue || m.MaxPrice.HasValue)
        {
            <span class="filter-tag">
                💰 @(m.MinPrice?.ToString("0.##") ?? "0")–@(m.MaxPrice?.ToString("0.##") ?? "∞")
                <a class="remove"
                   href="@m.RemoveFilters("minPrice", "maxPrice")"
                   hx-get="@m.RemoveFilters("minPrice", "maxPrice")"
                   hx-target="#games-container"
                   hx-push-url="true">×</a>
            </span>
        }

        @if (m.MinDiscount.HasValue)
        {
            <span class="filter-tag">
                🏷 ≥@m.MinDiscount%
                <a class="remove"
                   href="@m.RemoveFilter("minDiscount")"
                   hx-get="@m.RemoveFilter("minDiscount")"
                   hx-target="#games-container"
                   hx-push-url="true">×</a>
            </span>
        }

        @if (m.YearFrom.HasValue || m.YearTo.HasValue)
        {
            <span class="filter-tag">
                📅 @(m.YearFrom?.ToString() ?? "")–@(m.YearTo?.ToString() ?? "")
                <a class="remove"
                   href="@m.RemoveFilters("yearFrom", "yearTo")"
                   hx-get="@m.RemoveFilters("yearFrom", "yearTo")"
                   hx-target="#games-container"
                   hx-push-url="true">×</a>
            </span>
        }

        @if (m.MinRating.HasValue)
        {
            <span class="filter-tag">
                ⭐ ≥@m.MinRating%
                <a class="remove"
                   href="@m.RemoveFilter("minRating")"
                   hx-get="@m.RemoveFilter("minRating")"
                   hx-target="#games-container"
                   hx-push-url="true">×</a>
            </span>
        }

        @if (m.IsFree == true)
        {
            <span class="filter-tag">
                🆓 Безкоштовні
                <a class="remove"
                   href="@m.RemoveFilter("isFree")"
                   hx-get="@m.RemoveFilter("isFree")"
                   hx-target="#games-container"
                   hx-push-url="true">×</a>
            </span>
        }

        <a href="/Catalog"
           hx-get="/Catalog"
           hx-target="#games-container"
           hx-push-url="true"
           class="filter-tag" style="background:#fff3cd;">✕ Скинути всі</a>
    </div>
}

@* ── Sort bar + count ────────────────────────────────────────────────────── *@
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div class="sort-bar">
        <span class="text-muted small me-1">Сортувати:</span>

        <a href="@m.SortUrl(CatalogSortBy.Popularity)"
           hx-get="@m.SortUrl(CatalogSortBy.Popularity)"
           hx-target="#games-container"
           hx-push-url="true"
           class="@SortClass(CatalogSortBy.Popularity)">
            Популярність@(SortArrow(CatalogSortBy.Popularity))
        </a>

        <a href="@m.SortUrl(CatalogSortBy.Rating)"
           hx-get="@m.SortUrl(CatalogSortBy.Rating)"
           hx-target="#games-container"
           hx-push-url="true"
           class="@SortClass(CatalogSortBy.Rating)">
            Рейтинг@(SortArrow(CatalogSortBy.Rating))
        </a>

        <a href="@m.SortUrl(CatalogSortBy.Price)"
           hx-get="@m.SortUrl(CatalogSortBy.Price)"
           hx-target="#games-container"
           hx-push-url="true"
           class="@SortClass(CatalogSortBy.Price)">
            Ціна@(SortArrow(CatalogSortBy.Price))
        </a>

        <a href="@m.SortUrl(CatalogSortBy.Discount)"
           hx-get="@m.SortUrl(CatalogSortBy.Discount)"
           hx-target="#games-container"
           hx-push-url="true"
           class="@SortClass(CatalogSortBy.Discount)">
            Знижка@(SortArrow(CatalogSortBy.Discount))
        </a>

        <a href="@m.SortUrl(CatalogSortBy.ReleaseDate)"
           hx-get="@m.SortUrl(CatalogSortBy.ReleaseDate)"
           hx-target="#games-container"
           hx-push-url="true"
           class="@SortClass(CatalogSortBy.ReleaseDate)">
            Дата@(SortArrow(CatalogSortBy.ReleaseDate))
        </a>

        <a href="@m.SortUrl(CatalogSortBy.Name)"
           hx-get="@m.SortUrl(CatalogSortBy.Name)"
           hx-target="#games-container"
           hx-push-url="true"
           class="@SortClass(CatalogSortBy.Name)">
            Назва@(SortArrow(CatalogSortBy.Name))
        </a>
    </div>

    @if (m.Result.TotalCount > 0)
    {
        var from = (m.Result.Page - 1) * m.Result.PageSize + 1;
        var to   = Math.Min(m.Result.Page * m.Result.PageSize, m.Result.TotalCount);
        <div class="text-muted small">
            @from–@to з @m.Result.TotalCount
        </div>
    }
</div>

@* ── Flash-повідомлення колекцій ─────────────────────────────────────────── *@
@await Html.PartialAsync("_CollectionMessages")

@* ── Сітка карток або empty state ───────────────────────────────────────── *@
@if (m.Result.Items.Count == 0)
{
    <div class="text-center py-5 text-muted">
        <div style="font-size:3rem">🎮</div>
        <p class="mt-2">Ігор за вашими фільтрами не знайдено.</p>
        <a href="/Catalog"
           hx-get="/Catalog"
           hx-target="#games-container"
           hx-push-url="true"
           class="btn btn-outline-primary btn-sm">Скинути фільтри</a>
    </div>
}
else
{
    <div class="games-grid">
        @foreach (var game in m.Result.Items)
        {
            var returnUrl = m.CatalogReturnUrl();
            <div class="game-card-wrap">
                <a class="game-card" href="/Catalog/Details/@game.GameId">

                    @if (!string.IsNullOrEmpty(game.HeaderImage))
                    {
                        <img class="game-card-img"
                             src="@game.HeaderImage"
                             alt="@game.Name"
                             loading="lazy" />
                    }
                    else
                    {
                        <div class="game-card-img-placeholder">🎮</div>
                    }

                    <div class="game-card-body">
                        <div class="game-card-name" title="@game.Name">@game.Name</div>

                        @if (!string.IsNullOrEmpty(game.DeveloperName))
                        {
                            <div class="game-card-developer">@game.DeveloperName</div>
                        }

                        @if (game.Genres.Count > 0)
                        {
                            <div class="game-card-genres">
                                @foreach (var genre in game.Genres.Take(2))
                                {
                                    <span class="badge bg-secondary me-1">@genre</span>
                                }
                                @if (game.Genres.Count > 2)
                                {
                                    <span class="badge bg-light text-muted">+@(game.Genres.Count - 2)</span>
                                }
                            </div>
                        }

                        <div class="game-card-footer">
                            <div class="game-card-rating">
                                @if (game.Rating.HasValue)
                                {
                                    <span>⭐ @game.Rating.Value.ToString("0")%</span>
                                    @if (game.RatingCount.HasValue)
                                    {
                                        <span class="text-muted">(@game.RatingCount)</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </div>

                            <div class="game-card-price">
                                @if (game.IsFree)
                                {
                                    <span class="price-free">Безкоштовно</span>
                                }
                                else if (game.BestFinalPrice.HasValue)
                                {
                                    @if (game.BestDiscount > 0)
                                    {
                                        <div>
                                            <span class="discount-badge">-@game.BestDiscount%</span>
                                        </div>
                                        <div>
                                            <span class="price-original">
                                                @game.BestCurrentPrice?.ToString("0.##") @game.BestCurrency
                                            </span>
                                        </div>
                                    }
                                    <span class="price-current">
                                        @game.BestFinalPrice.Value.ToString("0.##") @game.BestCurrency
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted small">Ціна невідома</span>
                                }
                            </div>
                        </div>
                    </div>
                </a>

                @if (m.IsRegisteredUser)
                {
                    <partial name="_GameQuickActions"
                             model="@(new GameDB.Web.Pages.Shared.GameQuickActionsModel(
                                 game.GameId,
                                 m.WishlistIds.Contains(game.GameId),
                                 game.BestFinalPrice,
                                 returnUrl,
                                 UseDetailsRoute: false))" />
                }
            </div>
        }
    </div>
}

@* ── Пагінація ───────────────────────────────────────────────────────────── *@
@if (m.Result.TotalPages > 1)
{
    <nav class="mt-4" aria-label="Сторінки каталогу">
        <ul class="pagination justify-content-center flex-wrap">

            @if (m.Result.Page > 1)
            {
                <li class="page-item">
                    <a class="page-link"
                       href="@m.PageUrl(m.Result.Page - 1)"
                       hx-get="@m.PageUrl(m.Result.Page - 1)"
                       hx-target="#games-container"
                       hx-push-url="true"
                       aria-label="Попередня">‹</a>
                </li>
            }

            @{
                int startPage = Math.Max(1, m.Result.Page - 3);
                int endPage   = Math.Min(m.Result.TotalPages, m.Result.Page + 3);
            }

            @if (startPage > 1)
            {
                <li class="page-item">
                    <a class="page-link"
                       href="@m.PageUrl(1)"
                       hx-get="@m.PageUrl(1)"
                       hx-target="#games-container"
                       hx-push-url="true">1</a>
                </li>
                @if (startPage > 2)
                {
                    <li class="page-item disabled">
                        <span class="page-link">…</span>
                    </li>
                }
            }

            @for (int p = startPage; p <= endPage; p++)
            {
                <li class="page-item @(p == m.Result.Page ? "active" : "")">
                    <a class="page-link"
                       href="@m.PageUrl(p)"
                       hx-get="@m.PageUrl(p)"
                       hx-target="#games-container"
                       hx-push-url="true"
                       @(p == m.Result.Page ? "aria-current=\"page\"" : "")>@p</a>
                </li>
            }

            @if (endPage < m.Result.TotalPages)
            {
                @if (endPage < m.Result.TotalPages - 1)
                {
                    <li class="page-item disabled">
                        <span class="page-link">…</span>
                    </li>
                }
                <li class="page-item">
                    <a class="page-link"
                       href="@m.PageUrl(m.Result.TotalPages)"
                       hx-get="@m.PageUrl(m.Result.TotalPages)"
                       hx-target="#games-container"
                       hx-push-url="true">@m.Result.TotalPages</a>
                </li>
            }

            @if (m.Result.Page < m.Result.TotalPages)
            {
                <li class="page-item">
                    <a class="page-link"
                       href="@m.PageUrl(m.Result.Page + 1)"
                       hx-get="@m.PageUrl(m.Result.Page + 1)"
                       hx-target="#games-container"
                       hx-push-url="true"
                       aria-label="Наступна">›</a>
                </li>
            }

        </ul>
    </nav>
}
