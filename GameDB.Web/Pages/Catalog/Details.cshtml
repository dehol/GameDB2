@page "/Catalog/Details/{id:int}"
@using GameDB.Application.DTOs
@model GameDB.Web.Pages.Catalog.DetailsModel
@{
    ViewData["Title"] = Model.Game?.Name ?? "Картка гри";
    var g = Model.Game;
}

@section Styles {
    <link rel="stylesheet" href="~/css/catalog.css"     asp-append-version="true" />
    <link rel="stylesheet" href="~/css/collections.css" asp-append-version="true" />
}

@if (g is null)
{
    <div class="text-center py-5">
        <div style="font-size:3rem">🎮</div>
        <h2 class="mt-2">Гру не знайдено</h2>
        <a href="/Catalog" class="btn btn-primary mt-3">← До каталогу</a>
    </div>
    return;
}

@{
    decimal? bestPrice = g.Offers.Count > 0
        ? g.Offers.Min(o => o.FinalPrice ?? o.CurrentPrice)
        : (decimal?)null;

    string ShopColor(int i) => i switch
    {
        0 => "#1b9ef7",
        1 => "#f97316",
        2 => "#a78bfa",
        3 => "#34d399",
        4 => "#f87171",
        _ => "#94a3b8",
    };

    string returnUrl = $"/Catalog/Details/{g.GameId}";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb small">
        <li class="breadcrumb-item"><a href="/Catalog">Каталог</a></li>
        <li class="breadcrumb-item active" aria-current="page">@g.Name</li>
    </ol>
</nav>

@await Html.PartialAsync("_CollectionMessages")

<div class="game-detail">
    <div class="game-detail-hero">
        @if (!string.IsNullOrEmpty(g.HeaderImage))
        {
            <img class="game-detail-cover" src="@g.HeaderImage" alt="@g.Name" />
        }
        else
        {
            <div class="game-detail-cover-placeholder">🎮</div>
        }

        <div class="game-detail-meta">
            <h1 class="game-detail-title">@g.Name</h1>

            @if (!string.IsNullOrEmpty(g.DeveloperName) || !string.IsNullOrEmpty(g.PublisherName))
            {
                <div class="game-detail-company">
                    @if (!string.IsNullOrEmpty(g.DeveloperName))
                    {
                        <span><strong>Розробник:</strong> @g.DeveloperName</span>
                    }
                    @if (!string.IsNullOrEmpty(g.PublisherName))
                    {
                        <span class="ms-3"><strong>Видавець:</strong> @g.PublisherName</span>
                    }
                </div>
            }

            @if (g.ReleaseDate.HasValue)
            {
                <div class="text-muted small mt-1">
                    📅 Дата виходу: @g.ReleaseDate.Value.ToString("d MMMM yyyy")
                </div>
            }

            @if (g.Rating.HasValue)
            {
                var ratingClass = g.Rating.Value switch
                {
                    >= 80 => "rating-positive",
                    >= 60 => "rating-mixed",
                    _ => "rating-negative",
                };

                var ratingLabel = g.Rating.Value switch
                {
                    >= 95 => "Надзвичайно позитивні",
                    >= 80 => "Дуже позитивні",
                    >= 70 => "Переважно позитивні",
                    >= 60 => "Змішані",
                    >= 40 => "Переважно негативні",
                    _ => "Надзвичайно негативні",
                };

                <div class="game-detail-rating mt-2">
                    <span class="rating-pill @ratingClass">@g.Rating.Value.ToString("0")%</span>
                    <span class="text-muted small">@ratingLabel</span>
                </div>
            }

            @if (g.Genres.Count > 0)
            {
                <div class="mt-2">
                    @foreach (var genre in g.Genres)
                    {
                        <span class="badge bg-secondary me-1">@genre</span>
                    }
                </div>
            }

            @if (g.Tags.Count > 0)
            {
                <div class="mt-2">
                    @foreach (var tag in g.Tags.Take(10))
                    {
                        <span class="badge bg-light text-secondary border me-1 mb-1">@tag</span>
                    }
                    @if (g.Tags.Count > 10)
                    {
                        <span class="text-muted small">+@(g.Tags.Count - 10) тегів</span>
                    }
                </div>
            }

            @if (User.IsInRole("User"))
            {
                <div class="mt-3">
                    <partial name="_GameQuickActions"
                             model="@(new GameDB.Web.Pages.Shared.GameQuickActionsModel(
                                 g.GameId,
                                 Model.Collection?.InWishlist ?? false,
                                 bestPrice,
                                 returnUrl,
                                 UseDetailsRoute: true))" />
                </div>
            }
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.SanitizedDescription))
    {
        <div class="game-detail-description mt-4">
            <h2 class="h5">Про гру</h2>
            <div class="description-text">@Html.Raw(Model.SanitizedDescription)</div>
        </div>
    }

    @if (g.Offers.Count > 0)
    {
        <div class="mt-4">
            <h2 class="h5">Де купити</h2>
            <div class="table-responsive">
                <table class="table table-hover align-middle offers-table">
                    <thead class="table-dark">
                        <tr>
                            <th>Магазин</th>
                            <th class="text-end">Ціна</th>
                            <th class="text-end">Знижка</th>
                            <th class="text-end">Фінальна</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var offer in g.Offers.OrderBy(o => o.FinalPrice ?? o.CurrentPrice))
                        {
                            bool isFree = offer.CurrentPrice == 0;
                            <tr>
                                <td>
                                    <span class="badge bg-dark">@offer.ShopName</span>
                                </td>
                                <td class="text-end text-muted">
                                    @if (offer.Discount > 0)
                                    {
                                        <s>@offer.CurrentPrice.ToString("0.##") @offer.Currency</s>
                                    }
                                    else if (!isFree)
                                    {
                                        @offer.CurrentPrice.ToString("0.##") <text>@offer.Currency</text>
                                    }
                                </td>
                                <td class="text-end">
                                    @if (offer.Discount > 0)
                                    {
                                        <span class="discount-badge">-@offer.Discount%</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td class="text-end fw-bold">
                                    @if (isFree)
                                    {
                                        <span class="price-free">Безкоштовно</span>
                                    }
                                    else if (offer.FinalPrice.HasValue)
                                    {
                                        @offer.FinalPrice.Value.ToString("0.##") <text>@offer.Currency</text>
                                    }
                                    else
                                    {
                                        @offer.CurrentPrice.ToString("0.##") <text>@offer.Currency</text>
                                    }
                                </td>
                                <td class="text-end">
                                    @if (!string.IsNullOrEmpty(offer.DownloadUrl))
                                    {
                                        <a href="@offer.DownloadUrl"
                                           target="_blank"
                                           rel="noopener noreferrer"
                                           class="btn btn-sm btn-primary">Купити ↗</a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @if (Model.PriceHistory.Count > 0 && Model.PriceHistory.Any(h => h.Points.Count > 0))
    {
        <div class="mt-4">
            <h2 class="h5">Динаміка цін</h2>

            @if (Model.PriceHistory.Count > 1)
            {
                <div class="mb-2 d-flex flex-wrap gap-2" id="shopTabs">
                    <button class="btn btn-sm btn-outline-primary active"
                            data-shop="all"
                            onclick="priceChart.showShops('all', this)">Усі</button>
                    @for (int i = 0; i < Model.PriceHistory.Count; i++)
                    {
                        var hist = Model.PriceHistory[i];
                        var color = ShopColor(i);
                        <button class="btn btn-sm btn-outline-secondary"
                                data-shop="@hist.ShopName"
                                style="border-color:@color;color:@color"
                                onclick="priceChart.showShops('@hist.ShopName', this)">
                            @hist.ShopName
                        </button>
                    }
                </div>
            }

            <div class="price-chart-wrapper">
                <canvas id="priceHistoryChart"></canvas>
            </div>

            <div class="row g-2 mt-2">
                @for (int i = 0; i < Model.PriceHistory.Count; i++)
                {
                    var hist  = Model.PriceHistory[i];
                    var color = ShopColor(i);
                    if (hist.Points.Count > 0)
                    {
                        var atl = hist.Points.Min(p => p.Price * (100 - (p.DiscountPercent)) / 100);
                        var cur = hist.Points.FirstOrDefault()?.Currency ?? "";
                        <div class="col-auto">
                            <div class="card border-0 bg-light px-3 py-2 text-center">
                                <div class="small text-muted">@hist.ShopName ATL</div>
                                <div class="fw-bold" style="color:@color">
                                    @atl.ToString("0.##") @cur
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        
            decimal FinalPrice(PriceHistoryPointDto p) =>
                p.Price * (100 - (p.DiscountPercent)) / 100;
        

        <script id="priceHistoryData" type="application/json">
            @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.PriceHistory.Select((h, i) => new
                {
                    shopName   = h.ShopName,
                    shopColor  = ShopColor(i),
                    pricePoints = h.Points.Select(p => new
                    {
                        date  = p.RecordedAt.ToString("yyyy-MM-dd"),
                        price = FinalPrice(p)
                    })
                })
            ))
        </script>
    }

    @if (g.ExternalIds.Count > 0)
    {
        <div class="mt-4">
            <h2 class="h5">Зовнішні ідентифікатори</h2>
            <div class="d-flex flex-wrap gap-2">
                @foreach (var kv in g.ExternalIds)
                {
                    <span class="badge bg-light text-dark border">
                        @kv.Key: @kv.Value
                    </span>
                }
            </div>
        </div>
    }
</div>

@if (User.IsInRole("User") && Model.AlertContext is not null)
{
    <partial name="_PriceAlertModal" model="Model.AlertContext" />
}

@section Scripts {
    @if (Model.PriceHistory.Count > 0 && Model.PriceHistory.Any(h => h.Points.Count > 0))
    {
        <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"
                crossorigin="anonymous"></script>
        <script src="~/js/price-chart.js" asp-append-version="true"></script>
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                const raw  = document.getElementById('priceHistoryData');
                const data = raw ? JSON.parse(raw.textContent) : [];
                priceChart.init('priceHistoryChart', data);
            });
        </script>
    }
    @if (User.IsInRole("User") && Model.AlertContext is not null)
    {
        <script src="~/js/price-alert.js" asp-append-version="true"></script>
    }
}