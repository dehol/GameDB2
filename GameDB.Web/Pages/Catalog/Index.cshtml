@page "/Catalog"
@using GameDB.Application.DTOs
@model GameDB.Web.Pages.Catalog.IndexModel
@{
    ViewData["Title"] = "Каталог ігор";
    var m = Model;
}

@section Styles {
    <link rel="stylesheet" href="~/css/catalog.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/collections.css" asp-append-version="true" />
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Каталог ігор</h1>
</div>

<div class="catalog-layout">

    @* ══════════════════════════════════════════════════════════════════════════
       SIDEBAR — залишається на місці при HTMX-запитах.
       Форма є єдиним джерелом правди для фільтрів.

       hx-get:        URL обробника (OnGetAsync перевіряє HX-Request header)
       hx-target:     замінює innerHtml #games-container partial'ом
       hx-push-url:   синхронізує адресний рядок після кожного запиту
       hx-indicator:  показує spinner під час запиту
       hx-trigger:    «change» з debounce — для select/checkbox;
                      «keyup changed delay:500ms» з input[name=search] — для пошуку;
                      «submit» — кнопка «Застосувати»
    ══════════════════════════════════════════════════════════════════════════ *@
    <aside class="catalog-sidebar">
        <form id="filterForm"
              method="get"
              action="/Catalog"
              hx-get="/Catalog"
              hx-target="#games-container"
              hx-push-url="true"
              hx-indicator="#games-loading"
              hx-trigger="change delay:300ms, submit">

            @* Прихована синхронізація стану сортування і розміру сторінки.
               Оновлюється через htmx:afterSettle у JS нижче, щоб при зміні
               фільтра sort не скидався до дефолту. *@
            <input type="hidden" id="hiddenSortBy"   name="sortBy"   value="@m.SortBy" />
            <input type="hidden" id="hiddenSortDesc" name="sortDesc" value="@m.SortDesc.ToString().ToLower()" />
            <input type="hidden" id="hiddenPage"     name="page"     value="1" />
            <input type="hidden"                     name="pageSize" value="@m.PageSize" />

            @* ── Пошук ──────────────────────────────────────────────────────── *@
            <div class="sidebar-section">
                <div class="section-title">Пошук</div>
                <div class="input-group input-group-sm">
                    <input type="text"
                           name="search"
                           id="searchInput"
                           class="form-control"
                           placeholder="Назва гри..."
                           value="@m.Search"
                           autocomplete="off"
                           hx-get="/Catalog"
                           hx-target="#games-container"
                           hx-push-url="true"
                           hx-indicator="#games-loading"
                           hx-trigger="keyup changed delay:500ms"
                           hx-include="#filterForm" />
                    <button class="btn btn-outline-secondary" type="submit">🔍</button>
                </div>
            </div>

            @* ── Жанри ──────────────────────────────────────────────────────── *@
            @if (m.Sidebar.Genres.Count > 0)
            {
                <div class="sidebar-section">
                    <div class="section-title">Жанри</div>
                    <div class="genre-list-inner">
                        @foreach (var genre in m.Sidebar.Genres)
                        {
                            <div class="form-check d-flex align-items-center">
                                <input class="form-check-input"
                                       type="checkbox"
                                       name="genres"
                                       value="@genre.GenreId"
                                       id="g@(genre.GenreId)"
                                       @(m.Genres.Contains(genre.GenreId) ? "checked" : "") />
                                <label class="form-check-label flex-grow-1"
                                       for="g@(genre.GenreId)">@genre.Name</label>
                                <span class="genre-count">@genre.GameCount</span>
                            </div>
                        }
                    </div>
                </div>
            }

            @* ── Теги ────────────────────────────────────────────────────────── *@
            @if (m.Sidebar.Tags.Count > 0)
            {
                <div class="sidebar-section">
                    <div class="section-title">Теги</div>
                    <div class="genre-list-inner">
                        @foreach (var tag in m.Sidebar.Tags)
                        {
                            <div class="form-check d-flex align-items-center">
                                <input class="form-check-input"
                                       type="checkbox"
                                       name="tags"
                                       value="@tag.TagId"
                                       id="t@(tag.TagId)"
                                       @(m.Tags.Contains(tag.TagId) ? "checked" : "") />
                                <label class="form-check-label flex-grow-1"
                                       for="t@(tag.TagId)">@tag.Name</label>
                                <span class="genre-count">@tag.GameCount</span>
                            </div>
                        }
                    </div>
                </div>
            }

            @* ── Магазин ─────────────────────────────────────────────────────── *@
            @if (m.Sidebar.Shops.Count > 0)
            {
                <div class="sidebar-section">
                    <div class="section-title">Магазин</div>
                    <select name="shopId" class="form-select form-select-sm">
                        <option value="">Усі магазини</option>
                        @foreach (var shop in m.Sidebar.Shops)
                        {
                            @* <!option> вимикає OptionTagHelper і дозволяє @(...) в attribute area *@
                            <!option value="@shop.ShopId" @(m.ShopId == shop.ShopId ? "selected" : "")>@shop.Name</!option>
                        }
                    </select>
                </div>
            }

            @* ── Ціна ────────────────────────────────────────────────────────── *@
            <div class="sidebar-section">
                <div class="section-title">Ціна</div>
                <div class="d-flex gap-2">
                    <input type="number"
                           name="minPrice"
                           class="form-control form-control-sm"
                           placeholder="Від"
                           value="@m.MinPrice"
                           min="0"
                           step="0.01" />
                    <input type="number"
                           name="maxPrice"
                           class="form-control form-control-sm"
                           placeholder="До"
                           value="@m.MaxPrice"
                           min="0"
                           step="0.01" />
                </div>
                <div class="form-check mt-2">
                    <input class="form-check-input"
                           type="checkbox"
                           name="isFree"
                           value="true"
                           id="chkFree"
                           @(m.IsFree == true ? "checked" : "") />
                    <label class="form-check-label small" for="chkFree">
                        Тільки безкоштовні
                    </label>
                </div>
            </div>

            @* ── Мін. знижка ─────────────────────────────────────────────────── *@
            <div class="sidebar-section">
                <div class="section-title">Мін. знижка</div>
                <select name="minDiscount" class="form-select form-select-sm">
                    <option value="">Будь-яка</option>
                    @foreach (var pct in new[] { 10, 25, 50, 75, 90 })
                    {
                        <!option value="@pct" @(m.MinDiscount == pct ? "selected" : "")>≥ @pct%</!option>
                    }
                </select>
            </div>

            @* ── Мін. рейтинг ────────────────────────────────────────────────── *@
            <div class="sidebar-section">
                <div class="section-title">Мін. рейтинг</div>
                <select name="minRating" class="form-select form-select-sm">
                    <option value="">Будь-який</option>
                    @foreach (var r in new[] { 50.0, 60.0, 70.0, 80.0, 90.0 })
                    {
                        <!option value="@r" @(m.MinRating == r ? "selected" : "")>≥ @r%</!option>
                    }
                </select>
            </div>

            @* ── Рік випуску ─────────────────────────────────────────────────── *@
            <div class="sidebar-section">
                <div class="section-title">Рік випуску</div>
                <div class="d-flex gap-2">
                    <input type="number"
                           name="yearFrom"
                           class="form-control form-control-sm"
                           placeholder="З"
                           value="@m.YearFrom"
                           min="@m.Sidebar.MinYear"
                           max="@m.Sidebar.MaxYear" />
                    <input type="number"
                           name="yearTo"
                           class="form-control form-control-sm"
                           placeholder="По"
                           value="@m.YearTo"
                           min="@m.Sidebar.MinYear"
                           max="@m.Sidebar.MaxYear" />
                </div>
            </div>

            @* ── Розробник ───────────────────────────────────────────────────── *@
            @if (m.Sidebar.Developers.Count > 0)
            {
                <div class="sidebar-section">
                    <div class="section-title">Розробник</div>
                    <select name="developerId" class="form-select form-select-sm">
                        <option value="">Усі розробники</option>
                        @foreach (var dev in m.Sidebar.Developers)
                        {
                            <!option value="@dev.DeveloperId" @(m.DeveloperId == dev.DeveloperId ? "selected" : "")>@dev.Name</!option>
                        }
                    </select>
                </div>
            }

            @* ── Видавець ────────────────────────────────────────────────────── *@
            @if (m.Sidebar.Publishers.Count > 0)
            {
                <div class="sidebar-section">
                    <div class="section-title">Видавець</div>
                    <select name="publisherId" class="form-select form-select-sm">
                        <option value="">Усі видавці</option>
                        @foreach (var pub in m.Sidebar.Publishers)
                        {
                            <!option value="@pub.PublisherId" @(m.PublisherId == pub.PublisherId ? "selected" : "")>@pub.Name</!option>
                        }
                    </select>
                </div>
            }

            <div class="d-grid gap-2 mt-3">
                <button type="submit" class="btn btn-primary btn-sm">Застосувати</button>
                <a href="/Catalog"
                   hx-get="/Catalog"
                   hx-target="#games-container"
                   hx-push-url="true"
                   class="btn btn-outline-secondary btn-sm">Скинути фільтри</a>
            </div>

        </form>
    </aside>

    @* ══════════════════════════════════════════════════════════════════════════
       MAIN CONTENT
       #games-container — HTMX target: при кожному hx-get сюди вставляється
       HTML з _GamesListPartial (active filters + sort bar + grid + pagination).
       При звичайному GET partial рендериться inline через Html.PartialAsync.
    ══════════════════════════════════════════════════════════════════════════ *@
    <div class="catalog-main">

        @* Спіннер — видимий лише під час HTMX-запиту (клас htmx-request) *@
        <div id="games-loading" class="htmx-indicator catalog-loading">
            <div class="spinner-border spinner-border-sm text-primary" role="status">
                <span class="visually-hidden">Завантаження...</span>
            </div>
            <span class="ms-2 text-muted small">Пошук ігор...</span>
        </div>

        <div id="games-container">
            @await Html.PartialAsync("_GamesListPartial", Model)
        </div>

    </div>
</div>

@section Scripts {
    @* HTMX — підключається тут (специфічно для каталогу), а не в _Layout *@
    <script src="https://cdn.jsdelivr.net/npm/htmx.org@2.0.4/dist/htmx.min.js"
            crossorigin="anonymous"></script>

    <script>
    /**
     * catalogGoToPage(page) — єдина точка входу для пагінації каталогу.
     *
     * ЧОМУ не hx-get на самих лінках:
     *   HTMX v2 має регрес: елементи всередині #games-container після swap
     *   іноді не виконують DOM-оновлення через hx-get, навіть якщо запит
     *   проходить (сервер повертає 200 + partial). Симптом: URL змінюється
     *   (hx-push-url відпрацьовує), але контент залишається старим.
     *
     * РІШЕННЯ — filterForm.requestSubmit():
     *   filterForm знаходиться в sidebar (поза #games-container), тому ніколи
     *   не перезаписується swap-ом. Його HTMX-зв'язка гарантовано робоча.
     *   Встановлюємо hiddenPage → запускаємо submit → HTMX сам робить swap.
     *   Після settle скидаємо hiddenPage назад у 1, щоб зміна фільтрів
     *   завжди починала з першої сторінки.
     */
    window.catalogGoToPage = function (page) {
        document.getElementById('hiddenPage').value = page;
        document.getElementById('filterForm').requestSubmit();
        return false; // блокуємо дефолтну навігацію <a>
    };

    /**
     * Після кожного HTMX-settle:
     *   1. Синхронізуємо sortBy / sortDesc із URL (sort-лінки в partial
     *      змінюють URL через hx-push-url, форма повинна знати новий стан).
     *   2. Скидаємо hiddenPage → 1, щоб наступна зміна фільтра стартувала
     *      з першої сторінки (а не з тієї, на яку щойно перейшли).
     */
    document.body.addEventListener('htmx:afterSettle', function () {
        const params     = new URLSearchParams(window.location.search);
        const sortBy     = document.getElementById('hiddenSortBy');
        const sortDesc   = document.getElementById('hiddenSortDesc');
        const hiddenPage = document.getElementById('hiddenPage');

        if (sortBy   && params.has('sortBy'))   sortBy.value   = params.get('sortBy');
        if (sortDesc && params.has('sortDesc')) sortDesc.value = params.get('sortDesc');
        if (hiddenPage) hiddenPage.value = '1';
    });

    /**
     * При звичайному (не-HTMX) submit форми — прокидаємо поточне сортування
     * перед відправкою (на випадок класичного сабміту без JS або HTMX).
     */
    document.getElementById('filterForm')
        .addEventListener('submit', function () {
            const params   = new URLSearchParams(window.location.search);
            const sortBy   = document.getElementById('hiddenSortBy');
            const sortDesc = document.getElementById('hiddenSortDesc');
            if (params.has('sortBy')   && sortBy)   sortBy.value   = params.get('sortBy');
            if (params.has('sortDesc') && sortDesc) sortDesc.value = params.get('sortDesc');
        });
    </script>
}
