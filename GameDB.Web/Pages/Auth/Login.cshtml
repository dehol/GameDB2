@page
@model GameDB.Web.Pages.Auth.LoginModel
@{
    ViewData["Title"] = "Вхід";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h2 class="card-title mb-4 text-center">Вхід до GameDB</h2>

                @if (TempData["AuthError"] is string authError)
                {
                    <div class="alert alert-danger">@authError</div>
                }
                @if (!ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        <ul class="mb-0">
                            @foreach (var error in ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        </ul>
                    </div>
                }

                @* Email / пароль *@
                <form method="post" action="/auth/login?returnUrl=@Model.ReturnUrl">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label">Email</label>
                        <input asp-for="Input.Email" class="form-control" type="email" autofocus />
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label">Пароль</label>
                        <input asp-for="Input.Password" class="form-control" type="password" />
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>
                    <div class="mb-3 form-check">
                        <input asp-for="Input.RememberMe" class="form-check-input" type="checkbox" />
                        <label asp-for="Input.RememberMe" class="form-check-label">Запам'ятати мене</label>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 mb-2">Увійти</button>
                </form>

                <div class="text-center text-muted small my-2">або</div>

                @* Steam *@
                <a href="/auth/steam/login?returnUrl=@Model.ReturnUrl"
                   class="btn btn-outline-secondary w-100 d-flex align-items-center justify-content-center gap-2 mb-2">
                    <img src="https://store.steampowered.com/public/shared/images/header/logo_steam.svg"
                         height="18" alt="Steam" />
                    Увійти через Steam
                </a>

                <div class="text-center text-muted small my-2">або</div>

                @* Гість *@
                <form method="post" action="/auth/guest?returnUrl=@Model.ReturnUrl">
                    @Html.AntiForgeryToken()
                    <button type="submit"
                            class="btn btn-outline-secondary w-100 d-flex align-items-center justify-content-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                             fill="currentColor" viewBox="0 0 16 16">
                            <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4z"/>
                        </svg>
                        Продовжити як гість
                    </button>
                </form>

                <p class="text-muted text-center small mt-2 mb-0">
                    Гостьовий сеанс запам'ятовується для цього пристрою
                </p>

                <hr />
                <p class="text-center mb-0">
                    Ще немає акаунту?
                    <a asp-page="/Auth/Register"
                       asp-route-returnUrl="@Model.ReturnUrl">Зареєструватись</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
