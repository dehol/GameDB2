<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GameDB</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GameDB.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-page="/Index">GameDB</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-page="/Index">Головна</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("Guest"))
                            {
                                @* Гість — показуємо іконку + пропозицію зареєструватись *@
                                <li class="nav-item d-flex align-items-center me-2">
                                    <span class="text-muted small">
                                        👤 Гість
                                    </span>
                                </li>
                                <li class="nav-item">
                                    <a asp-page="/Auth/Register" class="btn btn-sm btn-primary me-1">
                                        Зареєструватись
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a asp-page="/Auth/Login" class="btn btn-sm btn-outline-secondary">
                                        Увійти
                                    </a>
                                </li>
                            }
                            else
                            {
                                @* Авторизований користувач *@
                                <li class="nav-item d-flex align-items-center me-3">
                                    <span class="text-dark small fw-semibold">
                                        👤 @User.Identity.Name
                                    </span>
                                </li>
                                <li class="nav-item">
                                    <form method="post" action="/auth/logout" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="btn btn-sm btn-outline-danger">
                                            Вийти
                                        </button>
                                    </form>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="nav-item">
                                <a asp-page="/Auth/Login" class="btn btn-sm btn-primary me-1">Увійти</a>
                            </li>
                            <li class="nav-item">
                                <a asp-page="/Auth/Register" class="btn btn-sm btn-outline-secondary">
                                    Реєстрація
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-4">
        <div class="container py-2">
            &copy; 2026 GameDB
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
